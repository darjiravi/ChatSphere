PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/chat-app
SESSION_SECRET=change_this_to_a_long_random_string
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# --- Production values (set these in your host's dashboard, not in a committed .env) ---
# MONGO_URI      = your MongoDB Atlas connection string (see README > Deployment)
# SESSION_SECRET = a long random string, different from dev (e.g. `openssl rand -hex 32`)
# CLIENT_URL     = the exact deployed frontend URL, no trailing slash
#                  e.g. https://your-app.vercel.app
# NODE_ENV       = production
